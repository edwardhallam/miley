{
	"extends": "../../tsconfig.base.json",
	"compilerOptions": {
		"outDir": "./dist",
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"baseUrl": "../../",
		"paths": {
			"miley-core": ["packages/core/src"],
			"miley-claude-runner": ["packages/claude-runner/src"],
			"miley-config-updater": ["packages/config-updater/src"],
			"miley-edge-worker": [
				"packages/edge-worker/dist/edge-worker/src/index.d.ts"
			]
		}
	},
	"include": ["*.ts", "src/**/*.ts"],
	"exclude": ["node_modules", "dist", "**/*.test.ts"]
}
